# Anthropic API Key (used by all agents)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Mock Service URLs (defaults work for local development)
CRM_SERVICE_URL=http://localhost:8001
TICKET_SERVICE_URL=http://localhost:8002

# UiPath Configuration (for cloud deployment)
UIPATH_TENANT_URL=https://cloud.uipath.com/your-org/your-tenant
UIPATH_CLIENT_ID=your-client-id
UIPATH_CLIENT_SECRET=your-client-secret
